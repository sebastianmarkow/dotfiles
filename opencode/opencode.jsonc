{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "share": "disabled",
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todoread": "allow",
    "todowrite": "ask",
    "edit": "deny",
    "external_directory": "ask",
    "sequential-thinking_sequentialthinking": "allow",
    "bash": {
      "*": "allow",

      // Package managers
      "brew install*": "ask",
      "npm install*": "ask",
      "go get*": "ask",
      "go install*": "ask",
      "uv add*": "ask",
      "uv pip install*": "ask",
      "uv run*": "ask",
      "uv lock*": "ask",
      "uv sync*": "ask",
      "pip install*": "ask",
      "poetry install*": "ask",

      // Filesystem destructive
      "mv *": "ask",
      "rm *": "ask",

      // Git
      "git push*": "deny",
      "git commit*": "ask",
      "git reset --hard*": "deny",
      "git clean*": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git checkout*": "allow",

      // Docker destructive/stateful
      "docker push*": "deny",
      "docker build*": "ask",
      "docker run*": "ask",
      "docker exec*": "ask",
      "docker stop*": "ask",
      "docker rm *": "ask",
      "docker rmi *": "ask",
      "docker compose up*": "ask",
      "docker compose down*": "ask",
      "docker compose restart*": "ask",

      // Make destructive
      "make clean*": "ask",
    },
  },
  "model": "portkey/vertex-opus",
  "small_model": "portkey/vertex-haiku",
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "target/**",
      ".next/**",
      ".nuxt/**",
      "*.pyc",
      ".opencode/**",
    ],
  },
  "provider": {
    "portkey": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Portkey",
      "options": {
        "baseURL": "https://api.portkey.ai/v1",
      },
      "models": {
        "vertex-opus": {
          "name": "Vertex Opus 4.6",
          "id": "@vertex-ai/anthropic.claude-opus-4-6",
          "limit": {
            "context": 200000,
            "output": 131072,
          },
          "options": {
            "max_tokens": 32768,
          },
          "cost": {
            "input": 5.0,
            "output": 25.0,
            "cache_write": 6.25,
            "cache_read": 0.5,
          },
        },
        "vertex-sonnet": {
          "name": "Vertex Sonnet 4.6",
          "id": "@vertex-ai/anthropic.claude-sonnet-4-6",
          "limit": {
            "context": 200000,
            "output": 65536,
          },
          "options": {
            "max_tokens": 16384,
          },
          "cost": {
            "input": 3.0,
            "output": 15.0,
            "cache_write": 3.75,
            "cache_read": 0.3,
          },
        },
        "vertex-haiku": {
          "name": "Vertex Haiku 4.5",
          "id": "@vertex-ai/anthropic.claude-haiku-4-5@20251001",
          "limit": {
            "context": 200000,
            "output": 65536,
          },
          "options": {
            "max_tokens": 8192,
          },
          "cost": {
            "input": 1.0,
            "output": 5.0,
            "cache_write": 1.25,
            "cache_read": 0.1,
          },
        },
      },
    },
  },
  "default_agent": "architect",
  "agent": {
    "plan": {
      "disable": true,
    },
    "build": {
      "disable": true,
    },
    "architect": {
      "model": "portkey/vertex-sonnet",
      "description": "Senior Staff Architect. Analyzes problems, selects workflow (TDD/Bug Fix/Refactor/Quick Fix/Exploration), and delegates to specialized subagents. Never writes code directly.",
      "prompt": "{file:./prompts/architect.md}",
      "temperature": 0.3,
      "color": "#c4a7e7",
      "steps": 50,
      "variant": "high",
      "options": {
        "max_tokens": 65536,
      },
      "permission": {
        "*": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          // Unix inspection
          "cat*": "allow",
          "find*": "allow",
          "grep*": "allow",
          "head*": "allow",
          "jq*": "allow",
          "ls*": "allow",
          "rg*": "allow",
          "tail*": "allow",
          "wc *": "allow",
          "yq*": "allow",
          "which *": "allow",
          "type *": "allow",
          "env": "allow",
          "uname*": "allow",
          // Git read-only
          "git *": "allow",
          "git commit*": "deny",
          "git reset*": "deny",
          "git push*": "deny",
          // Docker inspection
          "docker ps*": "allow",
          "docker images*": "allow",
          "docker inspect*": "allow",
          "docker network*": "allow",
          "docker volume*": "allow",
          "docker compose config*": "allow",
          "docker compose ps*": "allow",
          // Make inspection
          "make -n*": "allow",
          "make --dry-run*": "allow",
          "make help*": "allow",
          // Toolchain versions
          "go version*": "allow",
          "go list*": "allow",
          "go mod*": "allow",
          "node --version*": "allow",
          "npm list*": "allow",
          "python --version*": "allow",
          "pip list*": "allow",
          "uv version*": "allow",
          "uv pip list*": "allow",
          "uv tree*": "allow",
          "uv pip show*": "allow",
        },
      },
    },
    "research": {
      "mode": "subagent",
      "model": "portkey/vertex-sonnet",
      "description": "Research Engineer. Explores codebases, maps dependencies, looks up documentation via context7.",
      "prompt": "{file:./prompts/research.md}",
      "temperature": 0.1,
      "color": "#9ccfd8",
      "steps": 25,
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "codesearch": "allow",
        "lsp": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "context7_resolve-library-id": "allow",
        "context7_get-library-docs": "allow",
        "bash": {
          "*": "deny",
          // Unix inspection
          "cat*": "allow",
          "find*": "allow",
          "grep*": "allow",
          "head*": "allow",
          "ls*": "allow",
          "rg*": "allow",
          "tail*": "allow",
          "wc *": "allow",
          "which *": "allow",
          "type *": "allow",
          "env": "allow",
          "uname*": "allow",
          // Git read-only
          "git log*": "allow",
          "git show*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          // Docker inspection
          "docker ps*": "allow",
          "docker images*": "allow",
          "docker inspect*": "allow",
          "docker compose config*": "allow",
          "docker compose ps*": "allow",
          // Make inspection
          "make -n*": "allow",
          "make --dry-run*": "allow",
          "make help*": "allow",
          // Toolchain versions
          "go version*": "allow",
          "go list*": "allow",
          "go mod*": "allow",
          "node --version*": "allow",
          "npm list*": "allow",
          "python --version*": "allow",
          "pip list*": "allow",
          "uv version*": "allow",
          "uv pip list*": "allow",
          "uv tree*": "allow",
          "uv pip show*": "allow",
        },
      },
    },
    "code": {
      "mode": "subagent",
      "model": "portkey/vertex-sonnet",
      "description": "Senior Software Engineer. Receives scoped implementation tasks and writes clean, minimal, correct code.",
      "prompt": "{file:./prompts/code.md}",
      "temperature": 0.1,
      "color": "#3e8fb0",
      "steps": 25,
      "permission": {
        "*": "allow",
        "bash": {
          "*": "allow",

          // Package managers — ask before installing
          "brew install*": "ask",
          "npm install*": "ask",
          "go get*": "ask",
          "go install*": "ask",
          "uv add*": "ask",
          "uv pip install*": "ask",
          "pip install*": "ask",
          "poetry install*": "ask",

          // Filesystem destructive
          "mv *": "ask",
          "rm *": "ask",

          // Git — no push, no destructive resets
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean*": "deny",
          "git commit*": "ask",
        },
      },
    },
    "test": {
      "mode": "subagent",
      "model": "portkey/vertex-sonnet",
      "description": "Test Engineer. Writes tests (TDD Red phase or verification) and runs them. Supports both test-first and test-after workflows.",
      "prompt": "{file:./prompts/test.md}",
      "temperature": 0.1,
      "color": "#f6c177",
      "steps": 25,
      "permission": {
        "*": "allow",
        "bash": {
          "*": "allow",

          // Package managers — ask before installing
          "brew install*": "ask",
          "npm install*": "ask",
          "go get*": "ask",
          "go install*": "ask",
          "uv add*": "ask",
          "uv pip install*": "ask",
          "pip install*": "ask",
          "poetry install*": "ask",

          // Filesystem destructive
          "mv *": "ask",
          "rm *": "ask",

          // Git — deny all, test agent shouldn't touch git
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean*": "deny",
          "git commit*": "deny",
        },
      },
    },
    "review": {
      "mode": "subagent",
      "model": "portkey/vertex-sonnet",
      "description": "Code Reviewer. Reviews diffs for correctness, security, and logic errors. Returns structured severity-tagged findings.",
      "prompt": "{file:./prompts/review.md}",
      "temperature": 0.1,
      "color": "#ea9a97",
      "steps": 15,
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "codesearch": "allow",
        "lsp": "allow",
        "bash": {
          "*": "deny",
          // Git read-only
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          // Docker inspection (for reviewing infra changes)
          "docker compose config*": "allow",
          // Make inspection
          "make -n*": "allow",
          "make --dry-run*": "allow",
        },
      },
    },
    "debug": {
      "mode": "subagent",
      "model": "portkey/vertex-sonnet",
      "description": "Debug Engineer. Investigates bugs and produces structured root cause analysis. Diagnoses only, never fixes.",
      "prompt": "{file:./prompts/debug.md}",
      "temperature": 0.1,
      "color": "#eb6f92",
      "steps": 25,
      "variant": "medium",
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "codesearch": "allow",
        "lsp": "allow",
        "sequential-thinking_sequentialthinking": "allow",
        "bash": {
          "*": "deny",
          // Unix inspection
          "cat*": "allow",
          "find*": "allow",
          "grep*": "allow",
          "head*": "allow",
          "ls*": "allow",
          "rg*": "allow",
          "tail*": "allow",
          "wc *": "allow",
          "which *": "allow",
          "type *": "allow",
          "env": "allow",
          "uname*": "allow",
          // Git read-only
          "git log*": "allow",
          "git show*": "allow",
          "git diff*": "allow",
          "git blame*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          // Docker inspection + logs
          "docker ps*": "allow",
          "docker images*": "allow",
          "docker inspect*": "allow",
          "docker logs*": "allow",
          "docker compose config*": "allow",
          "docker compose ps*": "allow",
          "docker compose logs*": "allow",
          // Make inspection
          "make -n*": "allow",
          "make --dry-run*": "allow",
          "make help*": "allow",
          // Toolchain versions
          "go version*": "allow",
          "go list*": "allow",
          "go mod*": "allow",
          "node --version*": "allow",
          "npm list*": "allow",
          "python --version*": "allow",
          "pip list*": "allow",
          "uv version*": "allow",
          "uv pip list*": "allow",
          "uv tree*": "allow",
          "uv pip show*": "allow",
          // Test execution — for verifying hypotheses
          "go test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "npm test*": "allow",
          "npm run test*": "allow",
          "npx vitest*": "allow",
          "npx jest*": "allow",
          "make test*": "allow",
          "uv run pytest*": "allow",
          "cargo test*": "allow",
        },
      },
    },
    "document": {
      "mode": "subagent",
      "model": "portkey/vertex-haiku",
      "description": "Technical Writer. Creates and updates documentation focused on architecture and design decisions.",
      "prompt": "{file:./prompts/document.md}",
      "temperature": 0.2,
      "color": "#908caa",
      "steps": 15,
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow",
        "bash": "deny",
      },
    },
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking",
      ],
      "enabled": true,
      "timeout": 10000,
      "environment": {},
    },
    "memory-global": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory",
      ],
      "enabled": true,
      "timeout": 10000,
      "environment": {
        "MEMORY_FILE_PATH": "/Users/sklatt/.opencode/global-memory.json",
      },
    },
    "memory-project": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory",
      ],
      "enabled": true,
      "timeout": 10000,
      "environment": {
        "MEMORY_FILE_PATH": ".opencode/memory.json",
      },
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "timeout": 10000,
    },
  },
}

{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "share": "disabled",
  "snapshot": true,
  "permission": {
    // Harmless read/analysis tools — always allow
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "codesearch": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "task": "allow",
    "skill": "allow",
    "sequential-thinking_sequentialthinking": "allow",

    // Conscious actions — ask
    "todowrite": "ask",
    "doom_loop": "ask",
    "external_directory": {
      "~/**": "allow",
      "*": "ask",
    },

    // Hard gates
    "edit": "deny",

    "bash": {
      "*": "allow",

      // Package managers
      "brew install*": "ask",
      "npm install*": "ask",
      "go get*": "ask",
      "go install*": "ask",
      "uv add*": "ask",
      "uv pip install*": "ask",
      "uv run*": "ask",
      "uv lock*": "ask",
      "uv sync*": "ask",
      "pip install*": "ask",
      "poetry install*": "ask",

      // Filesystem destructive
      "mv *": "ask",
      "rm *": "ask",

      // Git
      "git push*": "deny",
      "git commit*": "ask",
      "git reset --hard*": "deny",
      "git clean*": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git checkout -b*": "allow",
      "git checkout --*": "ask",
      "git checkout*": "allow",

      // Docker destructive/stateful
      "docker push*": "deny",
      "docker build*": "allow",
      "docker run*": "allow",
      "docker exec*": "allow",
      "docker stop*": "allow",
      "docker rm *": "allow",
      "docker rmi *": "allow",
      "docker compose up*": "allow",
      "docker compose down*": "allow",
      "docker compose restart*": "allow",

      // Make destructive
      "make clean*": "ask",
    },
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "target/**",
      ".next/**",
      ".nuxt/**",
      "*.pyc",
      ".opencode/**",
    ],
  },
  "tool_output": {
    "max_lines": 300,
    "max_bytes": 32768,
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 15,
  },
  "experimental": {
    "continue_loop_on_deny": true,
  },
  "provider": {
    "requesty": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Requesty",
      "options": {
        "apiKey": "{env:REQUESTY_API_KEY}",
        "baseURL": "https://router.eu.requesty.ai/v1"
      },
      "models": {
        "opus": {
          "name": "Opus 4.8 (EU)",
          "id": "vertex/claude-opus-4-8@eu",
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "cache": true,
          "cost": {
            "input": 5.5,
            "output": 27.5
          }
        },
        "sonnet": {
          "name": "Sonnet 4.6 (EU)",
          "id": "vertex/claude-sonnet-4-6@europe-west1",
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "cache": true,
          "cost": {
            "input": 3.0,
            "output": 15.0
          }
        },
        "haiku": {
          "name": "Haiku 4.5 (EU)",
          "id": "vertex/claude-haiku-4-5@europe-west1",
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "cache": true,
          "cost": {
            "input": 1.0,
            "output": 5.0
          }
        },
      },
    },
  },
  "default_agent": "architect",
  "agent": {
    "plan": {
      "disable": true,
    },
    "build": {
      "disable": true,
    },
    "architect": {
      "description": "Senior Staff Architect. Analyzes problems, selects workflow (TDD/Bug Fix/Refactor/Quick Fix/Exploration), and delegates to specialized subagents. Never writes code directly.",
      "prompt": "{file:./prompts/architect.md}",
      "temperature": 0.3,
      "color": "#c4a7e7",
      "steps": 50,
      "options": {
        "max_tokens": 65536,
      },
      "permission": {
        "*": "deny",
        "task": {
          "*": "deny",
          "research": "allow",
          "code": "allow",
          "test": "allow",
          "review": "allow",
          "debug": "allow",
          "ml-researcher": "allow",
          "document": "allow",
        },
        "doom_loop": "allow",
        "skill": "allow",
        "question": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "memory_write_note": "allow",
        "memory_read_note": "allow",
        "memory_search_notes": "allow",
        "memory_search": "allow",
        "memory_build_context": "allow",
        "memory_recent_activity": "allow",
        "memory_list_directory": "allow",
        "memory_list_memory_projects": "allow",
        "todowrite": "ask",
        "sequential-thinking_sequentialthinking": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          // Unix inspection
          "cat*": "allow",
          "find*": "allow",
          "grep*": "allow",
          "head*": "allow",
          "jq*": "allow",
          "ls*": "allow",
          "rg*": "allow",
          "tail*": "allow",
          "wc *": "allow",
          "yq*": "allow",
          "which *": "allow",
          "type *": "allow",
          "env": "allow",
          "uname*": "allow",
          // Git read-only
          "git log*": "allow",
          "git show*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          "git blame*": "allow",
          // Docker inspection
          "docker ps*": "allow",
          "docker images*": "allow",
          "docker inspect*": "allow",
          "docker network*": "allow",
          "docker volume*": "allow",
          "docker compose config*": "allow",
          "docker compose ps*": "allow",
          // Make inspection
          "make -n*": "allow",
          "make --dry-run*": "allow",
          "make help*": "allow",
          // Toolchain versions
          "go version*": "allow",
          "go list*": "allow",
          "go mod*": "allow",
          "node --version*": "allow",
          "npm list*": "allow",
          "python --version*": "allow",
          "pip list*": "allow",
          "uv version*": "allow",
          "uv pip list*": "allow",
          "uv tree*": "allow",
          "uv pip show*": "allow",
          "uvx *": "allow",
        },
      },
    },
    "ml-researcher": {
        "description": "Senior ML researcher. Critiques experimental design, model architecture, training objective, and claims. Focuses on scientific validity, not engineering or serving. Read-only.",
        "mode": "subagent",
        "model": "requesty/opus",
        "temperature": 0.1,
        "color": "#31748f",
        "permission": {
          "task": "deny",
          "doom_loop": "allow",
          "skill": "deny",
          "question": "deny",
          "edit": "deny",
          "bash": "deny",
          "webfetch": "allow"
        },
        "prompt": "You are a senior ML staff researcher for computer vision reviewing the *scientific substance* of the general approach, experiment and model. You are not reviewing infra, serving, code style, or deployment. Your job is to find weaknesses in the approach itself and provide guidance.\n\nOutput format (always):\n\n## Verdict\nOne sentence: sound / sound-with-caveats / methodologically-flawed / fundamentally-flawed.\n\n## Threats to validity\nNumbered, ranked by severity. For each: the threat, why it invalidates or weakens the claim, and what evidence would resolve it.\n\n## Architecture critique\nWhat is justified, what is decorative, what is a confound. Be specific about which components are doing the work.\n\n## Experimental design issues\nBaselines, ablations, eval protocol, statistical rigor. Name what is missing, not just what is present.\n\n## Alternative framing\n2-5 sentences: how you would test this claim instead. Specific experiments, specific baselines, specific ablations. If the design is already sound, say so and stop.\n\n## Open questions\nThings that are not flaws but where the evidence is genuinely ambiguous and a follow-up experiment would clarify.\n\nRules:\n- Do not pad. If a section has nothing to say, write 'none' and move on.\n- Distinguish 'I am uncertain' from 'this is wrong'. Mark which.\n- Prefer 'this confound explains the result without invoking the proposed mechanism' over vague concerns.\n- Never recommend an experiment without naming what its outcome would prove or disprove."
    },
    "research": {
      "model": "requesty/sonnet",
      "mode": "subagent",
      "description": "Research Engineer. Explores codebases, maps dependencies, looks up documentation via context7.",
      "prompt": "{file:./prompts/research.md}",
      "temperature": 0.1,
      "color": "#9ccfd8",
      "steps": 50,
      "permission": {
        "*": "deny",
        "task": "deny",
        "doom_loop": "allow",
        "skill": "deny",
        "question": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "codesearch": "allow",
        "lsp": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "context7_resolve-library-id": "allow",
        "context7_query-docs": "allow",
        "bash": {
          "*": "deny",
          // Unix inspection
          "cat*": "allow",
          "find*": "allow",
          "grep*": "allow",
          "head*": "allow",
          "ls*": "allow",
          "rg*": "allow",
          "tail*": "allow",
          "wc *": "allow",
          "which *": "allow",
          "type *": "allow",
          "env": "allow",
          "uname*": "allow",
          // Git read-only
          "git log*": "allow",
          "git show*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          // Docker inspection
          "docker ps*": "allow",
          "docker images*": "allow",
          "docker inspect*": "allow",
          "docker compose config*": "allow",
          "docker compose ps*": "allow",
          "docker exec*": "allow",
          // Make inspection
          "make -n*": "allow",
          "make --dry-run*": "allow",
          "make help*": "allow",
          // Toolchain versions
          "go version*": "allow",
          "go list*": "allow",
          "go mod*": "allow",
          "node --version*": "allow",
          "npm list*": "allow",
          "python --version*": "allow",
          "pip list*": "allow",
          "uv version*": "allow",
          "uv pip list*": "allow",
          "uv tree*": "allow",
          "uv pip show*": "allow",
        },
      },
    },
    "code": {
      "model": "requesty/sonnet",
      "mode": "subagent",
      "description": "Senior Software Engineer. Receives scoped implementation tasks and writes clean, minimal, correct code.",
      "prompt": "{file:./prompts/code.md}",
      "temperature": 0.1,
      "color": "#3e8fb0",
      "steps": 50,
      "permission": {
        "*": "allow",
        "task": "allow",
        "doom_loop": "allow",
        "skill": "allow",
        "question": "allow",
        "bash": {
          "*": "allow",

          // Package managers — ask before installing
          "brew install*": "ask",
          "npm install*": "ask",
          "go get*": "ask",
          "go install*": "ask",
          "uv add*": "ask",
          "uv pip install*": "ask",
          "pip install*": "ask",
          "poetry install*": "ask",

          // Filesystem destructive
          "mv *": "ask",
          "rm *": "ask",

          // Docker
          "docker exec*": "allow",

          // Git — no push, no destructive resets
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean*": "deny",
          "git commit*": "ask",
        },
      },
    },
    "test": {
      "model": "requesty/sonnet",
      "mode": "subagent",
      "description": "Test Engineer. Writes tests (TDD Red phase or verification) and runs them. Supports both test-first and test-after workflows.",
      "prompt": "{file:./prompts/test.md}",
      "temperature": 0.1,
      "color": "#f6c177",
      "steps": 50,
      "permission": {
        "*": "allow",
        "task": "allow",
        "doom_loop": "allow",
        "skill": "allow",
        "question": "allow",
        "bash": {
          "*": "allow",

          // Package managers — ask before installing
          "brew install*": "ask",
          "npm install*": "ask",
          "go get*": "ask",
          "go install*": "ask",
          "uv add*": "ask",
          "uv pip install*": "ask",
          "pip install*": "ask",
          "poetry install*": "ask",

          // Filesystem destructive
          "mv *": "ask",
          "rm *": "ask",

          // Git — deny all, test agent shouldn't touch git
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean*": "deny",
          "git commit*": "deny",
        },
      },
    },
    "review": {
      "model": "requesty/sonnet",
      "mode": "subagent",
      "description": "Code Reviewer. Reviews diffs for correctness, security, and logic errors. Returns structured severity-tagged findings.",
      "prompt": "{file:./prompts/review.md}",
      "temperature": 0.1,
      "color": "#ea9a97",
      "steps": 50,
      "permission": {
        "*": "deny",
        "task": "deny",
        "doom_loop": "allow",
        "skill": "deny",
        "question": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "codesearch": "allow",
        "lsp": "allow",
        "bash": {
          "*": "deny",
          // Git read-only
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          // Docker inspection (for reviewing infra changes)
          "docker compose config*": "allow",
          "docker exec*": "allow",
          // Make inspection
          "make -n*": "allow",
          "make --dry-run*": "allow",
        },
      },
    },
    "debug": {
      "model": "requesty/sonnet",
      "mode": "subagent",
      "description": "Debug Engineer. Investigates bugs and produces structured root cause analysis. Diagnoses only, never fixes.",
      "prompt": "{file:./prompts/debug.md}",
      "temperature": 0.1,
      "color": "#eb6f92",
      "steps": 50,
      "permission": {
        "*": "deny",
        "task": "deny",
        "doom_loop": "allow",
        "skill": "deny",
        "question": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "codesearch": "allow",
        "lsp": "allow",
        "sequential-thinking_sequentialthinking": "allow",
        "bash": {
          "*": "deny",
          // Unix inspection
          "cat*": "allow",
          "find*": "allow",
          "grep*": "allow",
          "head*": "allow",
          "ls*": "allow",
          "rg*": "allow",
          "tail*": "allow",
          "wc *": "allow",
          "which *": "allow",
          "type *": "allow",
          "env": "allow",
          "uname*": "allow",
          // Git read-only
          "git log*": "allow",
          "git show*": "allow",
          "git diff*": "allow",
          "git blame*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          // Docker inspection + logs
          "docker ps*": "allow",
          "docker images*": "allow",
          "docker inspect*": "allow",
          "docker logs*": "allow",
          "docker compose config*": "allow",
          "docker compose ps*": "allow",
          "docker compose logs*": "allow",
          "docker exec*": "allow",
          // Make inspection
          "make -n*": "allow",
          "make --dry-run*": "allow",
          "make help*": "allow",
          // Toolchain versions
          "go version*": "allow",
          "go list*": "allow",
          "go mod*": "allow",
          "node --version*": "allow",
          "npm list*": "allow",
          "python --version*": "allow",
          "pip list*": "allow",
          "uv version*": "allow",
          "uv pip list*": "allow",
          "uv tree*": "allow",
          "uv pip show*": "allow",
          // Test execution — for verifying hypotheses
          "go test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "npm test*": "allow",
          "npm run test*": "allow",
          "npx vitest*": "allow",
          "npx jest*": "allow",
          "make test*": "allow",
          "uv run pytest*": "allow",
          "cargo test*": "allow",
        },
      },
    },
    "document": {
      "mode": "subagent",
      "model": "requesty/haiku",
      "description": "Technical Writer. Creates and updates documentation focused on architecture and design decisions.",
      "prompt": "{file:./prompts/document.md}",
      "temperature": 0.2,
      "color": "#908caa",
      "steps": 50,
      "permission": {
        "*": "deny",
        "task": "deny",
        "doom_loop": "allow",
        "skill": "deny",
        "question": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow",
        "bash": "deny",
      },
    },
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@2025.12.18",
      ],
      "enabled": true,
      "timeout": 10000,
      "environment": {},
    },
    "memory": {
      "type": "local",
      "command": [
        "uvx",
        "basic-memory==0.22.1",
        "mcp",
      ],
      "enabled": true,
      "timeout": 10000,
      "environment": {},
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 10000,
    },
    "web-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "open-websearch@2.1.11",
      ],
      "enabled": true,
      "timeout": 10000,
      "environment": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo",
      },
    },
  },
  "references": {
    "dotfiles": {
      "path": "~/Developer/repos/github.com/sebastianmarkow/dotfiles",
      "description": "Personal dotfiles: shell config, editor config, tool configs, and coding conventions",
    },
  },
}
